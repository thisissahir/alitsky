# Copy this file to `.env.local` for local development:
#   cp .env.local.example .env.local
#
# For production, set the same variables in Vercel:
#   https://vercel.com/theprogressivefamily-3374s-projects/alitsky/settings/environment-variables
#
# Sign up free at https://resend.com to get an API key.

RESEND_API_KEY=your_key_here

# Optional overrides (defaults shown):
# AUDIT_TO_EMAIL=hey@alitsky.com
# AUDIT_FROM_EMAIL=A Light in the Sky <onboarding@resend.dev>
#
# To send from audit@alitsky.com instead of onboarding@resend.dev:
#   1. Add and verify the alitsky.com domain in Resend (Domains → Add Domain)
#   2. Add the DNS records Resend gives you
#   3. Once verified, set AUDIT_FROM_EMAIL=A Light in the Sky <audit@alitsky.com>
